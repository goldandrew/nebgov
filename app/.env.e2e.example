# NebGov E2E Test Environment
# Copy this file to .env.e2e after running scripts/deploy-e2e-testnet.sh
#
# Instructions:
#   1. Run: ./scripts/deploy-e2e-testnet.sh
#   2. Get the secret key: stellar keys show e2e-test
#   3. Add TESTNET_SECRET_KEY below

# Test signer (funded by friendbot, delegated to self for voting power)
TESTNET_SECRET_KEY=S...

# Deployed contract addresses (populated by deploy-e2e-testnet.sh)
GOVERNOR_ADDRESS=C...
TIMELOCK_ADDRESS=C...
VOTES_ADDRESS=C...
TESTNET_RPC_URL=https://soroban-testnet.stellar.org

# Frontend env vars (populated by deploy-e2e-testnet.sh)
NEXT_PUBLIC_GOVERNOR_ADDRESS=C...
NEXT_PUBLIC_TIMELOCK_ADDRESS=C...
NEXT_PUBLIC_VOTES_ADDRESS=C...
NEXT_PUBLIC_NETWORK=testnet
